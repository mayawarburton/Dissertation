def plot_significant_umap(adata, cluster_col, targets, fname, legend_fontsize=5):
    """Plot a UMAP with `targets` colored individually and everything else gray."""
    plot_col = f"{cluster_col}_significant"
    adata.obs[plot_col] = np.where(
        adata.obs[cluster_col].astype(str).isin(targets),
        adata.obs[cluster_col].astype(str),
        "Other",
    )
    adata.obs[plot_col] = pd.Categorical(
        adata.obs[plot_col],
        categories=["Other"] + targets,  # "Other" first so it plots underneath, gray
        ordered=True,
    )

    # one distinct color per target cluster, gray for everything else
    palette = ["#D3D3D3"] + sc.pl.palettes.default_102[:len(targets)]

    sc.pl.umap(
        adata,
        color=plot_col,
        groups=["Other"] + targets,
        palette=palette,
        legend_loc="right margin",
        legend_fontsize=legend_fontsize,
        frameon=False,
        show=False,
    )
    plt.savefig(os.path.join(OUTDIR, fname), dpi=300, bbox_inches="tight")
    plt.close()

EMBED_REP = "X_embed"

adata_re = sc.read_h5ad(RECLUSTERED_DATA)
