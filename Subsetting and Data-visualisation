else:
    print(f"All {len(SIG_L4_CLUSTERS)} target clusters found in adata.obs['{L4_COL}'].")

plot_significant_umap(adata_re, L4_COL, SIG_L4_CLUSTERS, "L4_61_significant_clusters.png", LEGEND_FONTSIZE)
