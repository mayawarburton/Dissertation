    mc4r_pos = mc4r_expr > 0
    marker_pos = marker_expr > 0
    both_neg = ~mc4r_pos & ~marker_pos
    mc4r_only = mc4r_pos & ~marker_pos
    marker_only = ~mc4r_pos & marker_pos
    both_pos = mc4r_pos & marker_pos

    n_both_neg = int(both_neg.sum())
    n_mc4r_only = int(mc4r_only.sum())
    n_marker_only = int(marker_only.sum())
