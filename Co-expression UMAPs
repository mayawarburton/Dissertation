print("Creating 12 single-cluster coexpression UMAPs (re-embedded)...")
for i, (cluster, marker_gene) in enumerate(cluster_gene_pairs, start=1):
    print(f"\nPlotting {i}: {cluster} | Mc4r + {marker_gene}")

