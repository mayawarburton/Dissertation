        n_neighbors_actual = min(N_NEIGHBORS, adata_cluster.n_obs - 1)
    if n_neighbors_actual < 2:
        print(f"WARNING: cluster '{cluster}' has only {adata_cluster.n_obs} cells — too few to re-embed, skipping")
        continue

    print(f"  Re-computing neighbours (n_neighbors={n_neighbors_actual}) using '{USE_REP}'...")
    sc.pp.neighbors(adata_cluster, use_rep=USE_REP, n_neighbors=n_neighbors_actual)
    print("  Re-computing UMAP...")
