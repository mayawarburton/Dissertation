def get_gene_expr(adata_obj, gene, use_raw=True):
     if use_raw and adata_obj.raw is not None and gene in adata_obj.raw.var_names:
        x = adata_obj.raw[:, gene].X
    elif gene in adata_obj.var_names:
        x = adata_obj[:, gene].X
    else:
        raise ValueError(f"{gene} not found in adata.raw.var_names or adata.var_names")
    if hasattr(x, "toarray"):
        x = x.toarray()
    return np.asarray(x).flatten()


def centered_limits(x, y, pad=0.08):
     xmin, xmax = np.min(x), np.max(x)
    ymin, ymax = np.min(y), np.max(y)
    xmid = (xmin + xmax) / 2
    ymid = (ymin + ymax) / 2
    half_range = max(xmax - xmin, ymax - ymin) / 2
    half_range = half_range * (1 + pad)
    return (
        xmid - half_range,
        xmid + half_range,
        ymid - half_range,
        ymid + half_range,
    )


def safe_name(x):
    """Make a string safe to use in a filename."""
    return (
        x.replace("/", "-")
        .replace(" ", "_")
        .replace("+", "plus")
        .replace("|", "")
    )


def make_distinct_colors(n):
     cmaps = [
        plt.cm.tab20,
        plt.cm.tab20b,
        plt.cm.tab20c,
        plt.cm.Set3,
        plt.cm.Dark2,
        plt.cm.Accent,
    ]
    colors = []
    for cmap in cmaps:
        needed = n - len(colors)
        if needed <= 0:
            break
        steps = min(20, needed)
        colors.extend(cmap(np.linspace(0, 1, steps)))
    return colors[:n]


def add_cluster_number_labels(ax, x, y, labels, label_to_number):
      for label, number in label_to_number.items():
        mask = labels == label
        if mask.sum() == 0:
            continue
        x_med = np.median(x[mask])
        y_med = np.median(y[mask])
        ax.text(
            x_med,
            y_med,
            str(number),
            fontsize=8,
            fontweight="bold",
            ha="center",
            va="center",
            color="black",
            bbox=dict(
                boxstyle="circle,pad=0.2",
                facecolor="white",
                edgecolor="black",
                linewidth=0.5,
                alpha=0.85,
            ),
            zorder=10,
        )


